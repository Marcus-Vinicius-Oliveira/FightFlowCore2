# Copy this file to .env and fill in the values
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-byte-hex-secret-here

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host/dbname

# Restrict CORS in production (defaults to http://localhost:5173 in dev)
# FRONTEND_URL=https://your-app.com

# Port (optional, defaults to 5000)
# PORT=5000
