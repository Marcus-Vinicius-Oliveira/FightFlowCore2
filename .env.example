# Copy this file to .env and fill in the values
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-byte-hex-secret-here

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host/dbname

# Restrict CORS in production (defaults to http://localhost:5173 in dev)
# FRONTEND_URL=https://your-app.com

# Port (optional, defaults to 5000)
# PORT=5000

# ── Lembretes de mensalidade por e-mail (opcional) ───────────────────────────
# Sem SMTP_HOST, os lembretes são apenas registrados no log do servidor
# (nenhum e-mail real é enviado). Preencha para ativar o envio via SMTP.
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_USER=usuario@exemplo.com
# SMTP_PASS=senha-de-app
# SMTP_FROM="Academia <no-reply@exemplo.com>"
# Dias de antecedência do lembrete de vencimento (default: 3)
# PAYMENT_REMINDER_DAYS_BEFORE=3

# ── Lembretes de mensalidade por WhatsApp (opcional) ─────────────────────────
# Envio automático D-N via WhatsApp Cloud API oficial (Meta). Sem as duas
# variáveis abaixo, os lembretes WhatsApp são apenas registrados no log.
# Os botões manuais "Cobrar no WhatsApp" (wa.me) funcionam sem configuração.
# Requer: app Meta Business + número verificado + template pré-aprovado com
# 5 variáveis no corpo, na ordem: nome, plano, academia, valor, data.
# WHATSAPP_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Nome do template aprovado no WhatsApp Manager (default: lembrete_mensalidade)
# WHATSAPP_TEMPLATE_NAME=lembrete_mensalidade
